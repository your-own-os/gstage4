#!/usr/bin/python3
# -*- coding: utf-8; tab-width: 4; indent-tabs-mode: t -*-

import os
import sys
import json
import pathlib
import subprocess


def openCodeCall(workDir, prompt, logfile=None):
    env = os.environ.copy()
    env["OPENCODE_PERMISSION"] = '{"*": "allow"}'

    prompt = "You take the most appropriate action and output the result, there's no chance to interact with the user.\n\n" + prompt

    ret = subprocess.check_output(["opencode", "run", "--model", "opencode/big-pickle", "--dir", workDir, prompt],
                                    stderr=subprocess.STDOUT, text=True, env=env)

    if logfile is not None:
        pathlib.Path(logfile).write_text(ret)

    ret = ret.rstrip("\n").split("\n")[-2]      # the last output is "step_finish", the second to last output is the result
    ret = json.loads(ret)
    ret = ret["part"]["text"]
    ret = json.loads(ret)

    return ret


if __name__ == "__main__":
    if not os.path.exists("/usr/bin/opencode"):
        print("Error: opencode (dev-util/opencode-bin) is not installed.", file=sys.stderr)
        sys.exit(1)

    selfDir = os.path.dirname(os.path.realpath(__file__))

    projectFullDir = os.path.normpath(os.path.join(selfDir, ".."))

    patchRepoDir = os.path.join("libexec", "patch-repository.d")
    patchRepoFullDir = os.path.join(projectFullDir, patchRepoDir)

    cacheFullDir = os.path.join(selfDir, "cache")
    os.makedirs(cacheFullDir, exist_ok=True)

    prompt = f"""
You are helping maintain {patchRepoDir} in this project.

Actions:
- Read and comply with AGENTS.md in the project.
- Get to know all files and directories in patch-repository.d directory.
- Download / update the related gentoo repository / overlay from Internet into the cache directory so that you can analyse project code with them together. Don't put any local data into the cache directory, local data may be modified. Cache directory may already contains data from the last run.
- Review all files and directories in patch-repository.d to identify outdated content. Fix any outdated content you find.
- Do NOT run any thing, just read, anaylse, edit file
- Remove files or directories that are no longer needed (e.g., upstream bug fixes).
- Do NOT commit changes. Report what was fixed and what files remain outdated.

Project Directory: {projectFullDir}
Cache Directory: {cacheFullDir}
"""

    ret = openCodeCall(projectFullDir, prompt, logfile=os.path.join(cacheFullDir, "opencode.log"))
    print(ret)
 